# NexOps backend — environment configuration.
# Copy to ".env" (or export these) for any non-local / production run.
# Every value has a safe localhost default, so the demo runs with NOTHING set.

# --- Auth (SET THESE IN PRODUCTION) ---
# JWT signing secret. If unset, a random per-deployment secret is generated and
# persisted to nexops-backend/.jwt_secret (gitignored). Set explicitly in prod.
NEXOPS_JWT_SECRET=
# Send the session/CSRF cookies only over HTTPS (set to 1 behind TLS).
COOKIE_SECURE=
# Trust X-Forwarded-For for login rate-limiting (set to 1 behind a trusted proxy).
TRUST_PROXY=

# --- ARIA LLM keys (optional) ---
# If BOTH are empty, ARIA serves its deterministic OFFLINE template (demo still works).
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Demo seed password (optional) ---
# Password for ALL seeded demo users. Defaults to "nexops123" if unset.
NEXOPS_SEED_PASSWORD=

# --- Infrastructure (optional; localhost defaults shown) ---
MQTT_HOST=localhost
MQTT_PORT=1883
WS_HOST=0.0.0.0
WS_PORT=8000
DATABASE_URL=sqlite:///nexops.db
# Allowed browser origins for CORS (comma-separated). Default: localhost:3000.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
