# NexOps frontend — environment configuration.
# Copy to ".env.local". All values have working localhost defaults.

# The backend origin the Next.js same-origin proxy forwards /api/* to.
# (Keeps the httpOnly auth cookie first-party. Default: http://localhost:8000)
BACKEND_ORIGIN=http://localhost:8000

# WebSocket telemetry bridge URL (direct to backend; ticket-authenticated).
# Default: ws://localhost:8000/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Optional: override the same-origin API base (default "/api" via the proxy).
# Leave unset unless you intentionally bypass the proxy.
# NEXT_PUBLIC_API_BASE=/api
